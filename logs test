# -------- HELPER: SEND EMBED LOG --------
async def send_log(guild, log_type, embed: discord.Embed):
    guild_id = str(guild.id)
    if guild_id not in log_settings or log_type not in log_settings[guild_id]:
        return

    channel_id = log_settings[guild_id][log_type]
    channel = guild.get_channel(channel_id)
    if channel is None:
        try:
            channel = await bot.fetch_channel(channel_id)
        except (discord.NotFound, discord.Forbidden):
            return
        except Exception as e:
            print(f"[LOG] fetch error: {e}")
            return

    try:
        await channel.send(embed=embed)
    except discord.Forbidden:
        print(f"[LOG] Missing permissions in #{channel.name}")
    except Exception as e:
        print(f"[LOG] Send error: {e}")

