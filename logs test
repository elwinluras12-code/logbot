    embed.add_field(name="Message Created", value=f"<t:{int(message.created_at.timestamp())}:R>",  inline=False)
    embed.set_thumbnail(url=message.author.display_avatar.url)
    embed.set_footer(text=f"Guild: {message.guild.name}")
    await send_log(message.guild, "message_delete", embed)


