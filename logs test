# -------- UI: LOG TYPE SELECT (paginated into groups of 5) --------
class LogTypeSelect(discord.ui.Select):
    def __init__(self, options_slice):
        options = [
            discord.SelectOption(label=label, value=value)
            for label, value in options_slice
        ]
        super().__init__(
            placeholder="Select log type...",
            min_values=1,
            max_values=1,
            options=options
        )

    async def callback(self, interaction: discord.Interaction):
        self.view.log_type = self.values[0]
        await interaction.response.send_message(
            f"✅ Selected: **{self.values[0]}**\nNow choose a channel below.",
            ephemeral=True
        )

# -------- UI: CHANNEL SELECT --------
class LogChannelSelect(discord.ui.ChannelSelect):
    def __init__(self):
        super().__init__(
            placeholder="Select log channel...",
            min_values=1,
            max_values=1,
            channel_types=[discord.ChannelType.text]
        )

    async def callback(self, interaction: discord.Interaction):
        if not self.view.log_type:
            await interaction.response.send_message(
                "❌ Select a log type first!",
                ephemeral=True
            )
            return

        guild_id = str(interaction.guild.id)
        channel  = self.values[0]

        if guild_id not in log_settings:
            log_settings[guild_id] = {}

        log_settings[guild_id][self.view.log_type] = channel.id
        save_data(log_settings)

        print(f"[SETUP] Saved: guild={guild_id}, type={self.view.log_type}, channel={channel.id} ({channel.name})")

        await interaction.response.send_message(
            f"✅ Logs for **{self.view.log_type}** set to {channel.mention}",
            ephemeral=True
        )

# -------- VIEW (one page of 5 log types + channel picker) --------
class LogSetupView(discord.ui.View):
    def __init__(self, page=0):
        super().__init__(timeout=180)
        self.log_type = None
        self.page = page

        start = page * 5
        end   = start + 5
        self.add_item(LogTypeSelect(LOG_TYPES[start:end]))
        self.add_item(LogChannelSelect())

        if page > 0:
            self.add_item(PrevButton(page))
        if end < len(LOG_TYPES):
            self.add_item(NextButton(page))

class PrevButton(discord.ui.Button):
    def __init__(self, page):
        super().__init__(label="◀ Previous", style=discord.ButtonStyle.secondary)
        self.page = page

    async def callback(self, interaction: discord.Interaction):
        await interaction.response.edit_message(
            content="⚙️ **Logging Setup Panel**",
            view=LogSetupView(self.page - 1)
        )

class NextButton(discord.ui.Button):
    def __init__(self, page):
        super().__init__(label="Next ▶", style=discord.ButtonStyle.secondary)
        self.page = page

    async def callback(self, interaction: discord.Interaction):
        await interaction.response.edit_message(
            content="⚙️ **Logging Setup Panel**",
            view=LogSetupView(self.page + 1)
        )

# -------- SLASH COMMAND --------
@bot.tree.command(name="log", description="Setup logging system")
@app_commands.checks.has_permissions(administrator=True)
async def log_setup(interaction: discord.Interaction):
